{
  "name": "video-concat-service",
  "version": "1.0.0",
  "description": "Video concatenation service using Node.js and FFmpeg",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsnd --env-file=.env --respawn --transpile-only --exit-child -r tsconfig-paths/register src/api/server.ts",
    "build": "swc src -d dist --copy-files",
    "build:watch": "swc src -d dist --copy-files --watch",
    "start": "node dist/src/api/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest test/unit/ --verbose",
    "test:integration": "jest test/integration/ --runInBand --verbose --testTimeout=300000",
    "test:e2e": "jest --config=jest.e2e.config.js test/e2e/",
    "test:edital": "./test/integration/run-edital-tests.sh",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@supabase/supabase-js": "^2.39.0",
    "axios": "^1.11.0",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "form-data": "^4.0.4",
    "mammoth": "^1.9.1",
    "moment": "^2.30.1",
    "morgan": "^1.10.1",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "piscina": "^5.1.3",
    "serve-index": "^1.9.1",
    "tmp": "^0.2.3",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.18.3",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "@jest/globals": "^30.2.0",
    "@swc/cli": "^0.7.8",
    "@swc/core": "^1.13.2",
    "@swc/plugin-transform-imports": "^8.0.5",
    "@types/express": "^4.17.23",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.9",
    "@types/pdf-parse": "^1.1.5",
    "@types/serve-index": "^1.9.4",
    "@types/textract": "^2.4.5",
    "@types/tmp": "^0.2.6",
    "@types/word-extractor": "^1.0.6",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.4",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3"
  }
}
