{
  "name": "ocr-text-extraction-service",
  "version": "1.0.0",
  "description": "OCR and text extraction service for PDFs, documents, images, and audio",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsnd --env-file=.env --respawn --transpile-only --exit-child -r tsconfig-paths/register src/api/server.ts",
    "build": "swc src -d dist --copy-files && bun run scripts/generate-openapi-spec.mjs",
    "build:watch": "swc src -d dist --copy-files --watch",
    "start": "node dist/src/api/server.js",
    "test": "bun test",
    "lint": "biome lint src/",
    "lint:fix": "biome lint --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "check": "biome check src/",
    "check:fix": "biome check --write src/"
  },
  "dependencies": {
    "@types/cors": "^2.8.19",
    "@types/multer": "^2.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "axios": "^1.11.0",
    "cors": "^2.8.6",
    "express": "^4.21.2",
    "mammoth": "^1.9.1",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "openai": "^6.16.0",
    "p-limit": "^7.2.0",
    "pdf-parse": "^2.4.5",
    "piscina": "^5.1.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tmp": "^0.2.3",
    "tsconfig-paths": "^4.2.0",
    "winston": "^3.19.0",
    "word-extractor": "^1.0.4",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.10",
    "@swc/plugin-transform-imports": "^12.3.0",
    "@types/bun": "1.3.6",
    "@types/express": "^5.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.9",
    "@types/pdf-parse": "^1.1.5",
    "@types/textract": "^2.4.5",
    "@types/tmp": "^0.2.6",
    "@types/word-extractor": "^1.0.6",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.8.3"
  }
}
