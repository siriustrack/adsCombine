# Server
PORT=3000

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_IMAGE=gpt-4o-mini

# Claude AI
CLAUDE_AI_API_KEY=your_claude_api_key_here

# Stability AI
STABILITY_API_KEY=your_stability_api_key_here

# Supabase (Backend - use service_role para controle total)
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# SUPABASE_ANON_KEY=your_anon_key_here (opcional, use se frontend precisar)

# Transcription Service
TOKEN=your_transcription_token_here
BASE_URL=transcribe-ms-production.up.railway.app
REQUEST_LOGS_ENABLED=true
PROCESSING_CONCURRENCY=5

# Edital Processing Features
# Enable question count correction after orchestrator (optional)
ENABLE_QUESTION_FIXER=false